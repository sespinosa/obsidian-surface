{
  "name": "obsidian-surface",
  "version": "0.1.0",
  "description": "MCP server for Obsidian — rich display surface and knowledge workspace for AI tools, backed by Obsidian CLI.",
  "type": "module",
  "bin": {
    "obsidian-surface": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "obsidian",
    "mcp",
    "ai",
    "llm",
    "knowledge-management"
  ],
  "license": "MIT",
  "author": "sespinosa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sespinosa/obsidian-surface.git"
  },
  "homepage": "https://github.com/sespinosa/obsidian-surface#readme",
  "bugs": {
    "url": "https://github.com/sespinosa/obsidian-surface/issues"
  },
  "files": [
    "dist/",
    "!dist/__tests__/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
