{
  "name": "obsidian-surface",
  "version": "0.1.0",
  "description": "MCP server for Obsidian — rich display surface and knowledge workspace for AI tools, backed by Obsidian CLI.",
  "type": "module",
  "bin": {
    "obsidian-surface": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "echo 'No tests yet'"
  },
  "keywords": [
    "obsidian",
    "mcp",
    "ai",
    "llm",
    "knowledge-management"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
